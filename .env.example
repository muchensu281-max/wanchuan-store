# === Supabase 配置 ===
# 在 https://supabase.com/dashboard 创建项目后获取
SUPABASE_URL=https://你的项目.supabase.co
SUPABASE_ANON_KEY=你的anon-public-key
SUPABASE_SERVICE_ROLE_KEY=你的service-role-key（不要泄露）

# === Lemon Squeezy 配置 ===
# 在 https://app.lemonsqueezy.com/settings/api 获取
LEMON_SQUEEZY_API_KEY=你的api-key
LEMON_SQUEEZY_STORE_ID=你的商店id
LEMON_SQUEEZY_VARIANT_ID=你的商品变体id
# 在 Lemon Squeezy → Settings → Webhooks 生成
LEMON_SQUEEZY_WEBHOOK_SECRET=你的webhook密钥
